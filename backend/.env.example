# ==============================================================================
# Weatharr Backend - Environment Configuration Options
# ==============================================================================

# Listening port for the backend service
PORT=5000

# Mode for Express framework execution (production / development)
NODE_ENV=production

# ------------------------------------------------------------------------------
# Timezone enforcement inside all container logs and local databases (e.g. UTC, Australia/Adelaide)
TZ=UTC

# ==============================================================================
# Weather Forecasting Models Selection
# ==============================================================================
# The sync engine downloads weather forecasting grids for offline serving.
# Define a comma-separated list of model identifiers to ingest.
# Default is the global American GFS model (ncep_gfs013):
WEATHER_MODELS=ncep_gfs013

# Below are the top weather models supported by the Open-Meteo sync engine,
# cataloged by their target regions and available resolutions.
# Copy-paste the model codes into WEATHER_MODELS above based on your needs:
#
# -- GLOBAL & NORTH AMERICA MODELS --
# GFS (Global Forecast System - USA):
# * ncep_gfs013               - Global baseline (13km) [Default]
# * ncep_gfs025               - Global medium-res (25km)
# * ncep_gfs050               - Global low-res (50km)
# HRRR (High-Resolution Rapid Refresh - USA):
# * ncep_hrrr_conus_15min     - Continental USA high-res (3km, 15-minute intervals)
# * ncep_hrrr_alaska          - Alaska high-res (3km, hourly intervals)
# CMC GEM (Canadian Meteorological Centre):
# * cmc_gem_gdps              - Global baseline (15km)
# * cmc_gem_rdps              - North America regional (10km)
# * cmc_gem_hrdeps            - Canada local high-res (2.5km)
#
# -- EUROPE MODELS --
# ECMWF IFS (European Centre for Medium-Range Weather Forecasts):
# * ecmwf_ifs025              - Global baseline (25km)
# * ecmwf_ifs04               - Global low-res (40km)
# * ecmwf_aifs025             - Global Artificial Intelligence forecast model (25km)
# DWD ICON (German Weather Service):
# * dwd_icon                  - Global baseline (13km)
# * dwd_icon_eu               - Europe regional (7km)
# * dwd_icon_d2               - Central Europe local high-res (2.2km)
# Météo-France:
# * meteofrance_arome_france0025 - France local high-res (2.5km)
# * meteofrance_arpege_europe - Europe regional (10km)
# * meteofrance_arpege_world025  - Global baseline (25km)
#
# -- AUSTRALIA & ASIA MODELS --
# BOM ACCESS (Australian Bureau of Meteorology):
# * bom_access_global         - Global baseline (12km)
# * bom_access_c              - Australian Cities local high-res (1.5km)
# JMA (Japan Meteorological Agency):
# * jma_gsm                   - Global baseline (20km)
# * jma_msm                   - Japan local high-res (5km)
# KMA (Korea Meteorological Administration):
# * kma_gdps                  - Global baseline (12km)
# * kma_ldps                  - South Korea local high-res (1.5km)

# ------------------------------------------------------------------------------
# 🔒 SECURITY SETTINGS
# ------------------------------------------------------------------------------
# Set a numerical PIN or secure password to lock modifications.
# If configured, toggling the layout into "Edit Mode" to rearrange widgets,
# change typography, delete profiles, or save API keys will require entering this PIN.
# Leave blank to disable protection (layout edit lock can be toggled without authentication).
ADMIN_PIN=1234

# ------------------------------------------------------------------------------
# 📂 DATA STORAGE PATHS
# ------------------------------------------------------------------------------
# Path where layouts, widget configurations, and masked API keys are persisted
CONFIG_PATH=/app/data/weatharr_config.json
# Path where layout profiles are stored
PROFILES_PATH=/app/data/weatharr_profiles.json

# ------------------------------------------------------------------------------
# 📡 UPSTREAM ENDPOINTS
# ------------------------------------------------------------------------------
# Self-hosted open-meteo server URL (runs locally inside the docker-compose stack)
OPEN_METEO_URL=http://open-meteo:8080/v1/forecast
# Self-hosted air quality lookup server URL
AIR_QUALITY_URL=http://open-meteo:8080/v1/air-quality
# Public geocoding lookup API
GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
